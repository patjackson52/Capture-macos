{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capture-macos/assets/manifest.schema.json",
  "title": "Capture macOS Asset Manifest",
  "description": "Manifest for App Store and direct-distribution listing assets.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "platform", "channels"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "platform": {
      "const": "macos"
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "assets"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "description": {
            "type": "string"
          },
          "assets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "category",
                "fileType",
                "export",
                "placeholder",
                "format",
                "required"
              ],
              "properties": {
                "id": { "type": "string", "minLength": 3 },
                "category": {
                  "type": "string",
                  "enum": ["icon", "screenshot", "open-graph", "press-kit"]
                },
                "fileType": {
                  "type": "string",
                  "enum": ["image", "archive", "document"]
                },
                "export": { "type": "string", "minLength": 1 },
                "placeholder": { "type": "string", "minLength": 1 },
                "format": {
                  "type": "string",
                  "enum": ["png", "jpg", "jpeg", "zip", "pdf"]
                },
                "width": { "type": "integer", "minimum": 1 },
                "height": { "type": "integer", "minimum": 1 },
                "required": { "type": "boolean" },
                "notes": { "type": "string" }
              },
              "allOf": [
                {
                  "if": {
                    "properties": { "fileType": { "const": "image" } },
                    "required": ["fileType"]
                  },
                  "then": {
                    "required": ["width", "height"],
                    "properties": {
                      "format": { "enum": ["png", "jpg", "jpeg"] }
                    }
                  }
                },
                {
                  "if": {
                    "properties": { "fileType": { "const": "archive" } },
                    "required": ["fileType"]
                  },
                  "then": {
                    "properties": {
                      "format": { "const": "zip" }
                    }
                  }
                },
                {
                  "if": {
                    "properties": { "fileType": { "const": "document" } },
                    "required": ["fileType"]
                  },
                  "then": {
                    "properties": {
                      "format": { "const": "pdf" }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
